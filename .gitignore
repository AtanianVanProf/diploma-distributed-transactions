# ============================================================================
# Thesis Project .gitignore
# Stack: Java 21, Spring Boot, Gradle, PostgreSQL, Kafka, Angular, Docker
# ============================================================================

# ----------------------------------------------------------------------------
# Java
# ----------------------------------------------------------------------------
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# ----------------------------------------------------------------------------
# Gradle
# ----------------------------------------------------------------------------
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ----------------------------------------------------------------------------
# Spring Boot
# ----------------------------------------------------------------------------
application-local.yml
application-local.properties
application-secret.yml
application-secret.properties

# ----------------------------------------------------------------------------
# IntelliJ IDEA
# ----------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
out/
atlassian-ide-plugin.xml

# ----------------------------------------------------------------------------
# Eclipse (in case)
# ----------------------------------------------------------------------------
.classpath
.project
.settings/
bin/

# ----------------------------------------------------------------------------
# VS Code
# ----------------------------------------------------------------------------
.vscode/

# ----------------------------------------------------------------------------
# Angular / Node.js
# ----------------------------------------------------------------------------
node_modules/
dist/
tmp/
.angular/
.sass-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock

# Angular environment files (may contain secrets)
**/src/environments/environment.ts
**/src/environments/environment.prod.ts

# ----------------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# ----------------------------------------------------------------------------
# PostgreSQL data
# ----------------------------------------------------------------------------
pgdata/
postgres-data/
**/pg_data/
*.sql.gz

# ----------------------------------------------------------------------------
# Kafka / Zookeeper logs and data
# ----------------------------------------------------------------------------
kafka-logs/
kafka-data/
zookeeper-data/
zookeeper-logs/
**/kafka/data/
**/zookeeper/data/

# ----------------------------------------------------------------------------
# Environment and secrets
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks
*.keystore

# ----------------------------------------------------------------------------
# OS files
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
*.log
logs/
**/log/

# ----------------------------------------------------------------------------
# Terraform (if infrastructure-as-code is used)
# ----------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.backup

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
*.swp
*.swo
*~
.cache/
